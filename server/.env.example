# Copy this file to .env and fill in values. Never commit .env.

# From MongoDB Atlas → Connect → Drivers (replace <db_password>, add DB name in path if you like)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=iphonetrend

# Optional: database name (default iphone_trend)
# MONGODB_DB_NAME=iphone_trend

# Optional: lock CORS to your Vite app in production, e.g. https://your-app.vercel.app
# FRONTEND_ORIGIN=http://localhost:5173

# Optional: override port (default 8787)
# PORT=8787
